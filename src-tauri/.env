LUMINERIA_MODPACKS_API_URL=http://localhost:8000/modpacks.json
LUMINERIA_HTTP_TIMEOUT_SECS=15
LUMINERIA_DOWNLOAD_TIMEOUT_SECS=120
LUMINERIA_CONNECT_TIMEOUT_SECS=5

# ---- NUEVAS VARIABLES DE SETTINGS ----
LUMINERIA_RAM_MIN_MB=1024
LUMINERIA_RAM_MAX_MB=4096
LUMINERIA_JAVA_ARGS_EXTRA="-XX:+UseG1GC -Dsun.rmi.dgc.server.gcInterval=2147483646"