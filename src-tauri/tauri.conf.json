{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumineria Launcher",
  "version": "0.1.2",
  "identifier": "com.lumineria.launcher",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Lumineria Launcher",
        "width": 1050,
        "height": 800,
        "minWidth": 900,
        "minHeight": 650,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "opener": {
      "default": true
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM2NDk1RDQyRjQ4Qjk5RUYKUldUdm1ZdjBRbDFKTm05VjVtOE50M3lvaTRiTzI1OWx3Szg5dHlKSVRpemsrR2JzZE80RmRjUzAK",
      "endpoints": [
        "https://github.com/Duk3lo/lumineria_launcher/releases/latest/download/latest.json"
      ]
    }
  }
}