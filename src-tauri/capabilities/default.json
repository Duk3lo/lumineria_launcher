{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Permisos básicos para Lumineria Launcher",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "opener:default",
    "shell:allow-open",
    "shell:allow-execute",
    "updater:default",
    "process:allow-restart"
  ]
}